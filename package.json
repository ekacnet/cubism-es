{
  "name": "cubism-es",
  "version": "1.1.2",
  "description": "Cubism.js ES6 module, based on D3 V5 components",
  "main": "dist/cubism-es.js",
  "module": "dist/cubism-es.esm.js",
  "jsnext:main": "dist/cubism-es.esm.js",
  "scripts": {
    "_prebuild": "eslint src test",
    "build": "rollup -c",
    "dev": "rollup -c rollup.config.dev.js -w",
    "watch": "rollup -c -w",
    "pretest": "npm run build",
    "test:watch": "mocha --reporter min --watch --require ./test/testHelper.js --recursive",
    "test": "mocha --require ./test/testHelper.js --recursive",
    "test:cover": "nyc mocha --require ./test/testHelper.js --recursive",
    "prepublishOnly": "npm test",
    "pretty": "prettier --single-quote --trailing-comma es5 --write \"{src,__{tests,demo,dist}__}/**/*.js\""
  },
  "files": [
    "src",
    "dist"
  ],
  "dependencies": {
    "d3-axis": "^1.0.8",
    "d3-dispatch": "^1.0.3",
    "d3-fetch": "^1.1.0",
    "d3-format": "^1.3.0",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-selection": "^1.3.0",
    "d3-time": "^1.0.8",
    "d3-time-format": "^2.1.1",
    "d3-transition": "^3.0.1"
  },
  "peerDependencies": {
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.0.0",
    "@babel/core": "^7.0.0",
    "@babel/eslint-parser": "^7.0.0",
    "@babel/node": "^7.0.0",
    "@babel/plugin-transform-object-rest-spread": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "@babel/register": "^7.0.0",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "eslint": "^9.39.4",
    "istanbul": "^0.4.5",
    "mocha": "^11.7.5",
    "nyc": "^17.0.0",
    "prettier": "1.12.1",
    "rollup": "^4.59.1",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-local-resolve": "^1.0.7",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-serve": "^3.0.0",
    "rollup-watch": "^3.2.2"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BigFatDog/cubism-es.git"
  },
  "keywords": [
    "Cubism",
    "Time Series",
    "ES6",
    "Data Visualization",
    "D3",
    "D3V5"
  ],
  "author": {
    "name": "Yun Xing",
    "email": "ink.xing.yun@gmail.com",
    "url": "https://github.com/BigFatDog/"
  },
  "license": "MIT",
  "homepage": "https://github.com/BigFatDog/cubism-es"
}
